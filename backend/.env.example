# =============================================================================
# AI Platform — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env or .env.local to version control.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=5001

# ── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_CONNECT_RETRIES=5
MONGO_CONNECT_RETRY_DELAY_MS=2000
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

# ── Session / JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=<long-random-secret-min-32-chars>
JWT_ISSUER=ai-platform
JWT_AUDIENCE=ai-platform-users
TOKEN_TTL_MIN=30              # session lifetime in minutes
SESSION_COOKIE_NAME=ai_session
COOKIE_DOMAIN=                # set in production (e.g. echo-fy.com); leave blank in dev
PUBLIC_URL=http://localhost:3000   # full origin of the Next.js frontend

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Used only in development;
# production uses the hardcoded list in config/allowedOrigins.js.
ALLOWED_ORIGINS=https://echo-fy.com,https://www.echo-fy.com,http://localhost:3000,http://localhost:3002

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Addon pack price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_UPLOADS_5=price_...
STRIPE_PRICE_UPLOADS_20=price_...
STRIPE_PRICE_CHAT_100K=price_...
STRIPE_PRICE_VIDEOS_5=price_...
STRIPE_PRICE_VIDEOS_15=price_...
STRIPE_PRICE_VIDEOS_30=price_...

# ── AWS / Rekognition ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=            # optional — only for temporary credentials
AWS_REGION=us-east-1
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=<bucket-name>
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
PUBLIC_ASSET_BASE_URL=https://<cdn-or-r2-public-url>
REKOGNITION_REGION=us-east-1
REKOGNITION_COLLECTION_ID=<collection-id>
REKOGNITION_MATCH_THRESHOLD=90
REKOGNITION_VERIFY_MAX_FACES=25
FACE_VERIFY_THRESHOLD=90

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4-turbo
CHAT_CONTEXT_TOKENS_LIMIT=128000

# ── Google Vision ─────────────────────────────────────────────────────────────
GOOGLE_CLOUD_API_KEY=

# ── ElevenLabs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_EN_MALE_1=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_VOICE_EN_FEMALE_1=21m00Tcm4TlvDq8ikWAM

# ── HeyGen ────────────────────────────────────────────────────────────────────
HEYGEN_API_KEY=

# ── SadTalker / RunPod ────────────────────────────────────────────────────────
RUNPOD_API_KEY=
SADTALKER_RUNPOD_API_KEY=     # alias for RUNPOD_API_KEY
RUNPOD_TEMPLATE_ID=
RUNPOD_VOLUME_ID=
RUNPOD_GPU_TYPES=
RUNPOD_CLOUD_TYPE=COMMUNITY
RUNPOD_ALLOW_CREATE=false
RUNPOD_API_BASE_URL=https://rest.runpod.io/v1
RUNPOD_POD_NAME_PREFIX=sadtalker
RUNPOD_ENDPOINT_CACHE_MS=30000
RUNPOD_START_TIMEOUT_MS=480000
RUNPOD_POLL_INTERVAL_MS=10000
SADTALKER_RUNPOD_ENDPOINTS=   # comma-separated static endpoint URLs
SADTALKER_REDIS_URL=          # Redis URL for job queue
SADTALKER_WORKER_CONCURRENCY=1
SADTALKER_DOWNLOAD_TIMEOUT_MS=30000
SADTALKER_JOB_TIMEOUT_MS=480000
SADTALKER_MAX_IMAGE_BYTES=10485760
SADTALKER_MAX_AUDIO_BYTES=15728640
SADTALKER_REMOTE_API_KEY=
SADTALKER_REMOTE_CREATE_PATH=/v1/jobs
SADTALKER_REMOTE_STATUS_PATH=/v1/jobs
SADTALKER_TOKEN_QUERY=false
SADTALKER_HISTORY_LIMIT=50
SADTALKER_LITE_LIMIT=10
SADTALKER_PRO_LIMIT=50

# ── Internal auth ─────────────────────────────────────────────────────────────
INTERNAL_SECRET=<shared-secret-between-nextjs-and-express>
WORKER_TOKEN=<secret-for-render-internal-routes>
ADMIN_SECRET=<secret-for-debug-admin-endpoints>

# ── Recommendation tuning ─────────────────────────────────────────────────────
RECO_EXPLORATION_RATE=0.2
RECO_MIN_FEEDBACK_POSTS=3
RENDER_PREFLIGHT_FACE_CHECK=false
TRACK_UNLIMITED_CHAT_USAGE=false

# =============================================================================
# ⚠️  PRODUCTION CHECKLIST — flags that MUST NOT be set to true in production
# The server will refuse to start (process.exit 1) if any of these are set.
# =============================================================================
#
# CORS_ALLOW_ALL=true      → bypasses all CORS restrictions (boot guard)
# DEBUG_ERRORS=true        → leaks internal error details in API responses (boot guard)
# AUTH_DEBUG=true          → logs sensitive auth data (emails, tokens) (boot guard)
#
# Leave these unset or explicitly set to false in your production environment.
# =============================================================================
CORS_ALLOW_ALL=false
DEBUG_ERRORS=false
AUTH_DEBUG=false
