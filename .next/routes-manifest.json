      "page": "/[id]",
      "regex": "^/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
